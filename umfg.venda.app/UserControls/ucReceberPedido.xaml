<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">
    <Viewbox Stretch="Uniform">
        <Grid Background="#ECF0F1" Height="720" Width="1080">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition MinWidth="520" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <DataGrid ItemsSource="{Binding Pedido.Produtos}"
                          HeadersVisibility="None"
                          AutoGenerateColumns="False"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          GridLinesVisibility="None"
                          CanUserSortColumns="False"
                          CanUserAddRows="False"
                          Width="550"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGrid">
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Margin" Value="10,5,10,5"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Gray" Opacity="0.2" ShadowDepth="2" BlurRadius="5"/>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Black"/>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Imagem}" Height="110" Width="110" Stretch="Uniform" HorizontalAlignment="Center" Margin="10"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Referencia}" FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Left" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Descricao}" FontWeight="Bold" FontSize="22" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Valor, StringFormat='R$ {0:N2}'}" 
                                               FontWeight="ExtraBold" 
                                               FontSize="22" 
                                               Foreground="#27ae60"
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Right"
                                               Margin="0,0,20,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="10" Margin="10,20,20,20" Padding="30,20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" Opacity="0.15" ShadowDepth="2" BlurRadius="5"/>
                </Border.Effect>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Dados de Pagamento" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <ComboBox materialDesign:HintAssist.Hint="Tipo de Cartão" 
                              FontSize="20" FontWeight="SemiBold" 
                              SelectedIndex="{Binding TipoCartaoSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                              Margin="0,0,0,20" Padding="0,5">
                        <ComboBoxItem Content="Selecione um Cartão"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                    </ComboBox>

                    <TextBox materialDesign:HintAssist.Hint="Número do Cartão" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding NumeroCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DatePicker Name="dpValidade"
                                    materialDesign:HintAssist.Hint="Validade"
                                    materialDesign:HintAssist.HelperText="MM/yyyy"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Grid.Column="0"
                                    SelectedDate="{Binding DataValidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    CalendarOpened="DatePicker_CalendarOpened"
                                    FontSize="20" FontWeight="SemiBold"/>

                        <TextBox materialDesign:HintAssist.Hint="Código CVV" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Grid.Column="2"
                                 Text="{Binding CVV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 MaxLength="3" FontSize="20" FontWeight="SemiBold"/>
                    </Grid>

                    <TextBox materialDesign:HintAssist.Hint="Nome Impresso no Cartão" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding NomeCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="20" FontWeight="SemiBold" Margin="0,0,0,40"/>

                    <Button Content="CONCLUIR PAGAMENTO" 
                            Command="{Binding FinalizarCommand}" 
                            CommandParameter="{Binding}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="5"
                            FontSize="22" 
                            FontWeight="Bold" 
                            Background="#27ae60" 
                            BorderBrush="#27ae60"
                            Foreground="White" 
                            Height="55" />
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>