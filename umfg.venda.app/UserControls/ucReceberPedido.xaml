<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">
    <Viewbox Stretch="Uniform">
        <Grid Background="#ECF0F1" Height="720" Width="1080">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition MinWidth="500" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" 
                        Grid.Column="0"
                        Orientation="Horizontal">
                <DataGrid ItemsSource="{Binding Pedido.Produtos}"
                          HeadersVisibility="None"
                          AutoGenerateColumns="False"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          GridLinesVisibility="None"
                          CanUserSortColumns="False"
                          CanUserAddRows="False"
                          Width="550"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGrid">
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Margin" Value="10,5,10,5"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Gray" Opacity="0.2" ShadowDepth="2" BlurRadius="5"/>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Black"/>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Imagem}" Height="110" Width="110" Stretch="Uniform" HorizontalAlignment="Center" Margin="10"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Referencia}" FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Left" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Descricao}" FontWeight="Bold" FontSize="22" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Valor, StringFormat='R$ {0:N2}'}" 
                                               FontWeight="ExtraBold" 
                                               FontSize="22" 
                                               Foreground="#27ae60"
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Right"
                                               Margin="0,0,20,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Margin="0,15,20,0">
                <ComboBox FontSize="24" FontWeight="SemiBold" SelectedIndex="0" Width="500" Margin="0,0,0,10">
                    <ComboBoxItem Content="Selecione um Cartão"/>
                    <ComboBoxItem Content="Cartão de Crédito"/>
                    <ComboBoxItem Content="Cartão de Débito"/>
                </ComboBox>

                <TextBlock Text="Número do Cartão" FontSize="24" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NumeroCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TextBlock Text="Código CVV" FontSize="24" FontWeight="SemiBold"/>
                <TextBox Text="{Binding CVV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="3" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TextBlock Text="Data de Validade (MM/yyyy)" FontSize="24" FontWeight="SemiBold"/>
                <DatePicker SelectedDate="{Binding DataValidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="SemiBold" Height="40" Margin="0,0,0,10"/>

                <TextBlock Text="Nome no Cartão" FontSize="24" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NomeCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <Button Content="Receber via Command" 
                        Command="{Binding FinalizarCommand}" 
                        CommandParameter="{Binding}"
                        FontSize="24" 
                        FontWeight="Bold" 
                        Background="#27ae60" 
                        Foreground="White" 
                        Padding="0" />
            </StackPanel>
        </Grid>
    </Viewbox>
</UserControl>